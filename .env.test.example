# E2E tests (STEP-047) — copy to .env.test and fill in values.
# Requires a dedicated Supabase project (not production) with email confirmations disabled for signup tests.

E2E_TEST=1

# App under test (Playwright starts dev server locally; CI uses pnpm start after build)
PLAYWRIGHT_BASE_URL=http://localhost:3000

# Database + Supabase (same as local dev)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mileage_copilot
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Pre-seeded user for authenticated journeys (E2E-02–07)
E2E_USER_EMAIL=e2e-user@example.com
E2E_USER_PASSWORD=change-me-strong-password

# Signup journey (E2E-01) — Supabase must auto-confirm new signups
E2E_SIGNUP_ENABLED=1
E2E_SIGNUP_PASSWORD=E2eTestPass123!
E2E_SIGNUP_EMAIL_DOMAIN=example.com

# Receipt upload journey (E2E-04) — requires Supabase storage bucket
E2E_STORAGE_READY=1
STORAGE_BUCKET=receipts

# Optional: custom browser install path for CI
# PLAYWRIGHT_BROWSERS_PATH=0
