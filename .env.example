# Environment variables — copy to `.env.local` at repo root (never commit)

PROJECT_ROOT=H:/Travel-Expense

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Mileage & Expense Copilot

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server / Edge Functions only — NEVER NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AI — Edge Functions only
OPENAI_API_KEY=

# Email
RESEND_API_KEY=

# Monitoring (optional at scaffold)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Maps (optional — choose one at implementation)
