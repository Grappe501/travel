# Database (Neon / Supabase Postgres) — Slice 002
# Runtime: Supabase transaction pooler (port 6543)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# Prisma migrate: Supabase session pooler (port 5432) — direct db.*.host often IPv6-only (P1001)
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require"
# Local: copy to .env.local, then run `pnpm db:env:sync` to generate .env for Prisma CLI

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Mileage & Expense Copilot"

# Auth (Supabase) — Slice 003
# Dashboard may show "publishable key" (new) or "anon key" (legacy) — either name works.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."  # legacy name, optional if publishable key is set
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Stripe — Slice 010
# Production webhook URL: https://YOUR-SITE.netlify.app/api/stripe/webhook
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_SMALL_BUSINESS_MONTHLY="price_..."

# OpenAI — Slice 008 (set in Netlify for production OCR)
OPENAI_API_KEY="sk-..."

# Storage (Supabase) — Slice 007
STORAGE_BUCKET="receipts"
SUPABASE_STORAGE_URL="https://your-project.supabase.co/storage/v1"

# Email (optional — STEP-061 transactional)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="Mileage & Expense Copilot <noreply@yourdomain.com>"

# Monitoring — STEP-050 (optional; app runs without Sentry)
SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
NEXT_PUBLIC_SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
SENTRY_ENVIRONMENT="development"
# Staging only: POST /health/sentry-test to verify DSN
SENTRY_TEST_ENABLED="0"

# Admin — STEP-051 (support staff allowlist or Supabase app_metadata.role)
ADMIN_EMAIL_ALLOWLIST="support@example.com,admin@example.com"

# Integration tests (STEP-046) — optional local Postgres; CI uses service container
# INTEGRATION_TEST=1
# SKIP_INTEGRATION_TESTS=1

# E2E tests (STEP-047) — see docs/execution/E2E-SETUP.md and .env.test.example
# E2E_TEST=1
# E2E_USER_EMAIL=
# E2E_USER_PASSWORD=
