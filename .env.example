# Copy to .env.local after scaffold (never commit .env.local)
# All local development runs from H:\Travel-Expense

PROJECT_ROOT=H:/Travel-Expense

# Supabase — from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — Supabase Edge Functions secrets (NOT in Next.js client)
# SUPABASE_SERVICE_ROLE_KEY=
# OPENAI_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Stripe — publishable key only in client
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Mileage & Expense Copilot

# Optional maps (choose one provider at implementation)
# NEXT_PUBLIC_MAPBOX_TOKEN=
# NEXT_PUBLIC_GOOGLE_MAPS_KEY=
