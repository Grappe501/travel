// Mileage & Expense Copilot — V1 core schema (Volume 4)
// MEC-V1-S002 · Neon Postgres + Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Enums ---

enum RecordStatus {
  active
  archived
  deleted
}

enum AccountStatus {
  active
  suspended
  pending_deletion
  deleted
}

enum SubscriptionPlan {
  free
  pro
  small_business
  enterprise
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
  incomplete
}

enum BillingCycle {
  monthly
  annual
}

enum TripStatus {
  draft
  active
  completed
  deleted
}

enum MileageRateSource {
  irs
  company
  custom
  vehicle
  business
}

enum ReimbursementStatus {
  none
  pending
  submitted
  paid
}

enum FuelType {
  gas
  diesel
  electric
  hybrid
  other
}

enum UploadStatus {
  pending
  processing
  ready
  failed
}

enum ReviewStatus {
  pending
  confirmed
  rejected
}

enum ReportType {
  mileage
  expense
  combined
  client
  vehicle
}

enum ReportFormat {
  pdf
  csv
  xlsx
}

enum ReportStatus {
  pending
  ready
  failed
  expired
}

enum AuditAction {
  create
  update
  delete
  restore
}

enum AuditSource {
  web
  mobile
  api
  system
}

enum SuggestionType {
  duplicate_receipt
  missing_receipt
  category
  trip_association
  anomaly
}

enum SuggestionStatus {
  pending
  accepted
  rejected
  dismissed
}

enum AIInteractionOutcome {
  accepted
  rejected
  dismissed
  corrected
}

enum BusinessMemberRole {
  owner
  admin
  employee
}

enum BusinessMemberStatus {
  pending
  active
  suspended
  removed
}

enum FileAssetKind {
  receipt
  receipt_thumbnail
  export
  logo
  avatar
}

enum NotificationDeliveryMethod {
  in_app
  email
  push
}

enum MileageRateType {
  irs
  company
  custom
}

enum ProjectStatus {
  active
  completed
  archived
}

enum TripGpsPointSource {
  live
  start
  end
  sync_batch
}

enum TripMileageSource {
  odometer
  gps
  manual
  hybrid
}

// --- Models ---

model UserProfile {
  id                   String        @id @db.Uuid
  email                String
  displayName          String?       @map("display_name")
  firstName            String?       @map("first_name")
  lastName             String?       @map("last_name")
  phone                String?
  timezone             String        @default("UTC")
  language             String        @default("en-US") @db.Char(5)
  country              String?       @db.Char(2)
  avatarUrl            String?       @map("avatar_url")
  currency             String        @default("USD") @db.Char(3)
  taxYear              Int           @default(2026) @map("tax_year")
  mileageRateType      MileageRateType @default(irs) @map("mileage_rate_type")
  customMileageRate    Decimal?      @map("custom_mileage_rate") @db.Decimal(6, 4)
  accountStatus        AccountStatus @default(active) @map("account_status")
  emailVerified        Boolean       @default(false) @map("email_verified")
  onboardingCompleted  Boolean       @default(false) @map("onboarding_completed")
  notificationPrefs    Json          @default("{}") @map("notification_prefs")
  appPrefs             Json          @default("{}") @map("app_prefs")
  lastLoginAt          DateTime?     @map("last_login_at")
  deletedAt            DateTime?     @map("deleted_at")
  version              Int           @default(1)
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  subscription   Subscription?
  businesses     Business[]
  businessMembers BusinessMember[]
  vehicles       Vehicle[]
  mileageRates   MileageRate[]
  trips          Trip[]
  receipts       Receipt[]
  expenses       Expense[]
  reports        Report[]
  usageCounters  UsageCounter[]
  auditLogs      AuditLog[]
  businessEvents BusinessEvent[]
  aiSuggestions  AISuggestion[]
  fileAssets     FileAsset[]
  clients        Client[]
  projects       Project[]
  aiInteractionLogs AIInteractionLog[]
  notifications     Notification[]
  tripGpsPoints     TripGpsPoint[]

  @@index([email])
  @@map("profiles")
}

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  userId               String             @unique @map("user_id") @db.Uuid
  plan                 SubscriptionPlan   @default(free)
  billingCycle         BillingCycle?      @map("billing_cycle")
  status               SubscriptionStatus @default(active)
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  trialEndsAt          DateTime?          @map("trial_ends_at")
  currentPeriodStart   DateTime?          @map("current_period_start")
  currentPeriodEnd     DateTime?          @map("current_period_end")
  canceledAt           DateTime?          @map("canceled_at")
  featureFlags         Json?              @map("feature_flags")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model UsageCounter {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  periodMonth   DateTime @map("period_month") @db.Date
  tripsCount    Int      @default(0) @map("trips_count")
  receiptsCount Int      @default(0) @map("receipts_count")
  ocrCount      Int      @default(0) @map("ocr_count")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodMonth])
  @@map("usage_counters")
}

model Business {
  id                 String       @id @default(uuid()) @db.Uuid
  userId             String       @map("user_id") @db.Uuid
  name               String
  logoStoragePath    String?      @map("logo_storage_path")
  taxId              String?      @map("tax_id")
  address            Json?
  phone              String?
  website            String?
  currency           String       @default("USD") @db.Char(3)
  defaultMileageRate Decimal?     @map("default_mileage_rate") @db.Decimal(6, 4)
  timezone           String?
  isDefault          Boolean      @default(false) @map("is_default")
  recordStatus       RecordStatus @default(active) @map("record_status")
  deletedAt          DateTime?    @map("deleted_at")
  version            Int          @default(1)
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  user            UserProfile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  members         BusinessMember[]
  vehicles        Vehicle[]
  mileageRates    MileageRate[]
  trips           Trip[]
  receipts        Receipt[]
  expenses        Expense[]
  reports         Report[]
  businessEvents BusinessEvent[]
  clients        Client[]
  projects       Project[]

  @@index([userId])
  @@map("businesses")
}

model BusinessMember {
  id                      String               @id @default(uuid()) @db.Uuid
  businessId              String               @map("business_id") @db.Uuid
  userId                  String?              @map("user_id") @db.Uuid
  inviteEmail             String?              @map("invite_email")
  role                    BusinessMemberRole   @default(employee)
  status                  BusinessMemberStatus @default(pending)
  canApproveReimbursement Boolean              @default(false) @map("can_approve_reimbursement")
  joinedAt                DateTime?            @map("joined_at")
  recordStatus            RecordStatus         @default(active) @map("record_status")
  createdAt               DateTime             @default(now()) @map("created_at")
  updatedAt               DateTime             @updatedAt @map("updated_at")

  business Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     UserProfile? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@map("business_members")
}

model Vehicle {
  id                 String       @id @default(uuid()) @db.Uuid
  userId             String       @map("user_id") @db.Uuid
  businessId         String?      @map("business_id") @db.Uuid
  nickname           String
  make               String?
  model              String?
  year               Int?
  vin                String?
  licensePlate       String?      @map("license_plate")
  fuelType           FuelType?    @map("fuel_type")
  currentOdometer    Decimal?     @map("current_odometer") @db.Decimal(10, 1)
  defaultMileageRate Decimal?     @map("default_mileage_rate") @db.Decimal(6, 4)
  isDefault          Boolean      @default(false) @map("is_default")
  recordStatus       RecordStatus @default(active) @map("record_status")
  deletedAt          DateTime?    @map("deleted_at")
  version            Int          @default(1)
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  user     UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business?   @relation(fields: [businessId], references: [id], onDelete: SetNull)
  trips    Trip[]

  @@index([userId])
  @@map("vehicles")
}

model MileageRate {
  id            String            @id @default(uuid()) @db.Uuid
  userId        String?           @map("user_id") @db.Uuid
  businessId    String?           @map("business_id") @db.Uuid
  name          String
  rate          Decimal           @db.Decimal(6, 4)
  source        MileageRateSource
  effectiveFrom DateTime          @map("effective_from") @db.Date
  effectiveTo   DateTime?         @map("effective_to") @db.Date
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  user     UserProfile? @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business?    @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("mileage_rates")
}

model Client {
  id           String       @id @default(uuid()) @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  businessId   String?      @map("business_id") @db.Uuid
  name         String
  phone        String?
  email        String?
  notes        String?
  recordStatus RecordStatus @default(active) @map("record_status")
  deletedAt    DateTime?    @map("deleted_at")
  version      Int          @default(1)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  user     UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business?   @relation(fields: [businessId], references: [id], onDelete: SetNull)
  projects Project[]
  trips    Trip[]

  @@index([userId, name])
  @@index([businessId])
  @@map("clients")
}

model Project {
  id           String         @id @default(uuid()) @db.Uuid
  userId       String         @map("user_id") @db.Uuid
  businessId   String         @map("business_id") @db.Uuid
  clientId     String?        @map("client_id") @db.Uuid
  name         String
  status       ProjectStatus  @default(active)
  budget       Decimal?       @db.Decimal(12, 2)
  notes        String?
  recordStatus RecordStatus   @default(active) @map("record_status")
  deletedAt    DateTime?      @map("deleted_at")
  version      Int            @default(1)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  user     UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business    @relation(fields: [businessId], references: [id], onDelete: Restrict)
  client   Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  trips    Trip[]

  @@index([clientId])
  @@index([businessId, status])
  @@map("projects")
}

model Trip {
  id                  String              @id @default(uuid()) @db.Uuid
  userId              String              @map("user_id") @db.Uuid
  businessId          String              @map("business_id") @db.Uuid
  vehicleId           String              @map("vehicle_id") @db.Uuid
  clientId            String?             @map("client_id") @db.Uuid
  projectId           String?             @map("project_id") @db.Uuid
  clientName          String?             @map("client_name")
  projectName         String?             @map("project_name")
  status              TripStatus          @default(draft)
  purpose             String
  destination         String?
  startLocation       String?             @map("start_location")
  endLocation         String?             @map("end_location")
  startOdometer       Decimal?            @map("start_odometer") @db.Decimal(10, 1)
  endOdometer         Decimal?            @map("end_odometer") @db.Decimal(10, 1)
  miles               Decimal?            @db.Decimal(10, 1)
  mileageRate         Decimal?            @map("mileage_rate") @db.Decimal(6, 4)
  mileageRateSource   MileageRateSource?  @map("mileage_rate_source")
  reimbursementAmount Decimal?            @map("reimbursement_amount") @db.Decimal(10, 2)
  expenseTotal        Decimal?            @map("expense_total") @db.Decimal(10, 2)
  grandTotal          Decimal?            @map("grand_total") @db.Decimal(10, 2)
  notes               String?
  trackingEnabled     Boolean             @default(false) @map("tracking_enabled")
  trackingStartedAt   DateTime?           @map("tracking_started_at")
  trackingStoppedAt   DateTime?           @map("tracking_stopped_at")
  startLatitude       Decimal?            @map("start_latitude") @db.Decimal(9, 6)
  startLongitude      Decimal?            @map("start_longitude") @db.Decimal(9, 6)
  endLatitude         Decimal?            @map("end_latitude") @db.Decimal(9, 6)
  endLongitude        Decimal?            @map("end_longitude") @db.Decimal(9, 6)
  gpsMiles            Decimal?            @map("gps_miles") @db.Decimal(10, 1)
  mileageSource       TripMileageSource?  @map("mileage_source")
  mileageReviewRequired Boolean           @default(false) @map("mileage_review_required")
  reimbursementStatus ReimbursementStatus  @default(none) @map("reimbursement_status")
  startedAt           DateTime?           @map("started_at")
  endedAt             DateTime?           @map("ended_at")
  recordStatus        RecordStatus        @default(active) @map("record_status")
  deletedAt           DateTime?           @map("deleted_at")
  version             Int                 @default(1)
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  business  Business    @relation(fields: [businessId], references: [id], onDelete: Restrict)
  vehicle   Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  client    Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project   Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  receipts  Receipt[]
  expenses  Expense[]
  gpsPoints TripGpsPoint[]

  @@index([userId, status])
  @@index([businessId, startedAt(sort: Desc)])
  @@map("trips")
}

model TripGpsPoint {
  id          String             @id @default(uuid()) @db.Uuid
  tripId      String             @map("trip_id") @db.Uuid
  userId      String             @map("user_id") @db.Uuid
  latitude    Decimal            @db.Decimal(9, 6)
  longitude   Decimal            @db.Decimal(9, 6)
  accuracyM   Decimal?           @map("accuracy_m") @db.Decimal(8, 2)
  altitudeM   Decimal?           @map("altitude_m") @db.Decimal(8, 2)
  speedMps    Decimal?           @map("speed_mps") @db.Decimal(8, 2)
  heading     Decimal?           @db.Decimal(6, 2)
  recordedAt  DateTime           @map("recorded_at")
  source      TripGpsPointSource @default(live)
  createdAt   DateTime           @default(now()) @map("created_at")

  trip Trip        @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tripId, recordedAt])
  @@index([userId, recordedAt])
  @@map("trip_gps_points")
}

model Receipt {
  id                   String       @id @default(uuid()) @db.Uuid
  userId               String       @map("user_id") @db.Uuid
  businessId           String?      @map("business_id") @db.Uuid
  tripId               String?      @map("trip_id") @db.Uuid
  storagePath          String       @map("storage_path")
  thumbnailPath        String?      @map("thumbnail_path")
  fileHash             String?      @map("file_hash")
  fileSizeBytes        Int?         @map("file_size_bytes")
  mimeType             String?      @map("mime_type")
  merchant             String?
  receiptDate          DateTime?    @map("receipt_date") @db.Date
  subtotal             Decimal?     @db.Decimal(10, 2)
  tax                  Decimal?     @db.Decimal(10, 2)
  total                Decimal?     @db.Decimal(10, 2)
  currency             String       @default("USD") @db.Char(3)
  ocrConfidence        Decimal?     @map("ocr_confidence") @db.Decimal(3, 2)
  uploadStatus         UploadStatus @default(pending) @map("upload_status")
  reviewStatus         ReviewStatus @default(pending) @map("review_status")
  idempotencyKey       String?      @map("idempotency_key") @db.Uuid
  recordStatus         RecordStatus @default(active) @map("record_status")
  deletedAt            DateTime?    @map("deleted_at")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  user     UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business?   @relation(fields: [businessId], references: [id], onDelete: SetNull)
  trip     Trip?       @relation(fields: [tripId], references: [id], onDelete: SetNull)
  ocrResult OCRResult?
  expenses Expense[]
  fileAssets FileAsset[]

  @@index([userId, fileHash])
  @@unique([userId, idempotencyKey])
  @@map("receipts")
}

model Expense {
  id            String       @id @default(uuid()) @db.Uuid
  userId        String       @map("user_id") @db.Uuid
  businessId    String       @map("business_id") @db.Uuid
  tripId        String?      @map("trip_id") @db.Uuid
  receiptId     String?      @map("receipt_id") @db.Uuid
  categorySlug  String       @default("other") @map("category_slug")
  merchant      String?
  amount        Decimal      @db.Decimal(10, 2)
  taxAmount     Decimal?     @map("tax_amount") @db.Decimal(10, 2)
  currency      String       @default("USD") @db.Char(3)
  expenseDate   DateTime     @map("expense_date") @db.Date
  paymentMethod String?      @map("payment_method")
  notes         String?
  recordStatus  RecordStatus @default(active) @map("record_status")
  deletedAt     DateTime?    @map("deleted_at")
  version       Int          @default(1)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  user     UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business    @relation(fields: [businessId], references: [id], onDelete: Restrict)
  trip     Trip?       @relation(fields: [tripId], references: [id], onDelete: SetNull)
  receipt  Receipt?    @relation(fields: [receiptId], references: [id], onDelete: SetNull)

  @@index([tripId])
  @@index([userId, expenseDate(sort: Desc)])
  @@map("expenses")
}

model Report {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  businessId     String?      @map("business_id") @db.Uuid
  reportType     ReportType   @map("report_type")
  dateRangeStart DateTime     @map("date_range_start") @db.Date
  dateRangeEnd   DateTime     @map("date_range_end") @db.Date
  format         ReportFormat
  filters        Json?
  storagePath    String?      @map("storage_path")
  fileHash       String?      @map("file_hash")
  fileSizeBytes  Int?         @map("file_size_bytes")
  status         ReportStatus @default(pending)
  errorMessage   String?      @map("error_message")
  generatedAt    DateTime?    @map("generated_at")
  expiresAt      DateTime?    @map("expires_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  user     UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business?   @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([userId, generatedAt(sort: Desc)])
  @@map("reports")
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String      @map("user_id") @db.Uuid
  entityType String      @map("entity_type")
  entityId   String      @map("entity_id") @db.Uuid
  action     AuditAction
  oldValues  Json?       @map("old_values")
  newValues  Json?       @map("new_values")
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  source     AuditSource @default(web)
  createdAt  DateTime    @default(now()) @map("created_at")

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("audit_logs")
}

model BusinessEvent {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  businessId    String?   @map("business_id") @db.Uuid
  eventType     String    @map("event_type")
  entityType    String?   @map("entity_type")
  entityId      String?   @map("entity_id") @db.Uuid
  payload       Json?
  correlationId String?   @map("correlation_id") @db.Uuid
  occurredAt    DateTime  @map("occurred_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  user     UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business?   @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt(sort: Desc)])
  @@index([entityType, entityId])
  @@map("business_events")
}

model OCRResult {
  id                  String    @id @default(uuid()) @db.Uuid
  receiptId           String    @unique @map("receipt_id") @db.Uuid
  rawResponse         Json?     @map("raw_response")
  merchant            String?
  receiptDate         DateTime? @map("receipt_date") @db.Date
  subtotal            Decimal?  @db.Decimal(10, 2)
  tax                 Decimal?  @db.Decimal(10, 2)
  total               Decimal?  @db.Decimal(10, 2)
  suggestedCategorySlug String? @map("suggested_category_slug")
  confidenceScores    Json?     @map("confidence_scores")
  processingEngine    String?   @map("processing_engine")
  modelVersion        String?   @map("model_version")
  processedAt         DateTime? @map("processed_at")

  receipt Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@map("ocr_results")
}

model AISuggestion {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @map("user_id") @db.Uuid
  suggestionType  SuggestionType   @map("suggestion_type")
  entityType      String           @map("entity_type")
  entityId        String           @map("entity_id") @db.Uuid
  suggestedValue  Json?            @map("suggested_value")
  message         String?
  status          SuggestionStatus @default(pending)
  createdAt       DateTime         @default(now()) @map("created_at")
  resolvedAt      DateTime?        @map("resolved_at")

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  interactionLogs AIInteractionLog[]

  @@index([userId, status])
  @@map("ai_suggestions")
}

model AIInteractionLog {
  id              String               @id @default(uuid()) @db.Uuid
  userId          String               @map("user_id") @db.Uuid
  suggestionId    String?              @map("suggestion_id") @db.Uuid
  interactionType String               @map("interaction_type")
  entityType      String?              @map("entity_type")
  entityId        String?              @map("entity_id") @db.Uuid
  stage           String?
  outcome         AIInteractionOutcome
  accepted        Boolean?
  confidence      Decimal?             @db.Decimal(3, 2)
  engineVersion   String?              @map("engine_version")
  processingMs    Int?                 @map("processing_ms")
  metadata        Json?
  createdAt       DateTime             @default(now()) @map("created_at")

  user       UserProfile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  suggestion AISuggestion? @relation(fields: [suggestionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([suggestionId])
  @@map("ai_interaction_log")
}

model FileAsset {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @map("user_id") @db.Uuid
  kind          FileAssetKind
  storagePath   String        @map("storage_path")
  mimeType      String?       @map("mime_type")
  fileSizeBytes Int?          @map("file_size_bytes")
  fileHash      String?       @map("file_hash")
  entityType    String?       @map("entity_type")
  entityId      String?       @map("entity_id") @db.Uuid
  receiptId     String?       @map("receipt_id") @db.Uuid
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user    UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  receipt Receipt?    @relation(fields: [receiptId], references: [id], onDelete: SetNull)

  @@index([userId, kind])
  @@index([entityType, entityId])
  @@map("file_assets")
}

model Notification {
  id              String                     @id @default(uuid()) @db.Uuid
  userId          String                     @map("user_id") @db.Uuid
  type            String
  title           String
  body            String
  payload         Json?
  deliveryMethod  NotificationDeliveryMethod @default(in_app) @map("delivery_method")
  dedupeKey       String                     @map("dedupe_key")
  readAt          DateTime?                  @map("read_at")
  deliveredAt     DateTime?                  @map("delivered_at")
  createdAt       DateTime                   @default(now()) @map("created_at")
  updatedAt       DateTime                   @updatedAt @map("updated_at")

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([userId, readAt, createdAt(sort: Desc)])
  @@map("notifications")
}
