{
  "name": "mileage-expense-copilot",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "@prisma/client": "^6.19.3"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "lint": "pnpm --filter web lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:integration": "pnpm --filter web test:integration",
    "test:e2e": "pnpm --filter web test:e2e",
    "test:e2e:smoke": "pnpm --filter web test:e2e:smoke",
    "test:e2e:a11y": "pnpm --filter web test:e2e:a11y",
    "test:coverage": "pnpm --filter @mileage-copilot/shared test:coverage",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "postinstall": "prisma generate",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "5.15.11",
    "prettier": "^3.4.2",
    "prisma": "^6.19.3"
  }
}
